      "parameters": {
        "jsCode": "const chatInput = $json[\"CHAT INPUT\"] || \"\";\n\nconst urlMatch = chatInput.match(/https:\\/\\/[a-zA-Z0-9-]+\\.ngrok-free\\.dev/);\n\nif (urlMatch) {\n  return [{\n    json: {\n      apiUrl: urlMatch[0],\n      hasUrl: true,\n      originalMessage: chatInput\n    }\n  }];\n} else {\n  return [{\n    json: {\n      apiUrl: \"https://arlena-unfavorite-unpropitiously.ngrok-free.dev\", // ← ESTA es tu URL real\n      hasUrl: false,\n      chatInput: chatInput\n    }\n  }];\n}"
      },
