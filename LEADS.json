    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "/*\n  OBJETIVO:\n  1. Recibir el objeto \"$json\" fusionado (lead + html).\n  2. Extraer el email del HTML (que está en $json.data).\n  3. Devolver el objeto del lead completo con el email encontrado.\n*/\n\n// Usamos un try...catch para que un error en una web no pare todo el bucle\ntry {\n  \n  // 1. El HTML de la página web (viene de HTTP Request1)\n  const html = $json.data || \"\";\n\n  // 2. Los datos ORIGINALES del lead (vienen de \"Loop Over Items\")\n  // ¡Ahora están todos en $json gracias al Merge!\n  const leadData = $json;\n\n  // 3. Extraer todos los emails del HTML\n  const emailRegex = /\\b[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}\\b/gi;\n  const allEmails = [...new Set(html.match(emailRegex) || [])];\n\n  // 4. Filtrar emails no deseados (basura, genéricos, imágenes)\n  const validEmails = allEmails.filter(email => {\n    const lower = email.toLowerCase();\n    \n    // Lista de palabras a excluir\n    const excludeList = [\n      'google', 'example', 'sentry', 'wixpress', \n      'privacy', 'dominio', 'domain', 'cpanel', 'webmaster'\n    ];\n    \n    // Lista de terminaciones a excluir (ej. emails falsos en archivos de imagen)\n    const excludeEndings = ['.png', '.jpg', '.jpeg', '.gif', '.webp'];\n\n    const containsExcludedWord = excludeList.some(word => lower.includes(word));\n    const hasExcludedEnding = excludeEndings.some(ending => lower.endsWith(ending));\n\n    return !containsExcludedWord && !hasExcludedEnding;\n  });\n\n  // 5. Quedarse con el primer email válido, o un texto vacío si no hay\n  const email = validEmails[0] || \"\";\n\n  // 6. Devolver el objeto COMPLETO\n  //    Combinamos los datos originales de leadData con el email encontrado\n  return {\n    json: {\n      name: leadData.name || \"\",\n      website: leadData.website || \"\",\n      address: leadData.address || \"\",\n      email: email, // ¡Aquí va el email que acabamos de encontrar!\n      phone: leadData.phone || \"\",\n      rating: leadData.rating || \"\",\n      reviews: leadData.reviews || \"\",\n      category: leadData.category || \"\",\n      sector: leadData.sector || \"\"\n    }\n  };\n\n} catch (error) {\n  // SI ALGO FALLA:\n  // No lanzamos un error nuevo. Solo registramos el fallo en la consola\n  // y devolvemos el lead original sin email, para que el flujo continúe.\n  console.log(`Error procesando web: ${$json.website || 'URL desconocida'}. Error: ${error.message}`);\n  \n  return {\n    json: {\n      name: $json.name || \"\",\n      website: $json.website || \"\",\n      address: $json.address || \"\",\n      email: $json.email || \"\", // Devolvemos email vacío porque falló la extracción\n      phone: $json.phone || \"\",\n      rating: $json.rating || \"\",\n      reviews: $json.reviews || \"\",\n      category: $json.category || \"\",\n      sector: $json.sector || \"\"\n    }\n  };\n}"
      },
