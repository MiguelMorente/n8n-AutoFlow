      "parameters": {
        "jsCode": "// La respuesta de la API viene directamente en $json\nconst raw = $json;\n\n// Extraer los leads de la respuesta\nconst leads = raw.leads || [];\n\n// Obtener el sector del nodo \"Estructura URL\"\nconst sector = $('Estructura URL').first().json.sector || \"\";\n\n// Mapear cada lead a la estructura limpia\nconst results = leads.map(lead => ({\n  json: {\n    name: lead.name || \"\",\n    website: lead.website || null,\n    address: lead.address || \"\",\n    email: \"\", // Se buscará después\n    phone: lead.phone || \"\",\n    rating: lead.ratingScore || \"\",\n    reviews: lead.reviewCount || \"\",\n    category: lead.category || sector,\n    sector: sector\n  }\n}));\n\n// Filtrar solo los leads que tienen website\nreturn results.filter(item => item.json.website);"
      },
