      "parameters": {
        "jsCode": "// Lee DIRECTAMENTE el texto del input, tal como lo solicitas\nlet rawText = $input.first().json.content.parts[0].text;\n\n// Inicializa el objeto de salida\nlet outputObj = {\n  sector: \"\",\n  location: \"\",\n  limit: 20,\n  minRating: 4,\n  minReviews: 50,\n  searchQuery: \"\"\n};\n\ntry {\n  // Extrae el JSON real del texto (quitando ```json y espacios)\n  const jsonMatch = rawText.match(/```json\\s*({[\\s\\S]*?})\\s*```/);\n\n  if (jsonMatch && jsonMatch[1]) {\n    // Parsea el JSON extraído\n    const parsedJson = JSON.parse(jsonMatch[1]);\n\n    // Asigna los valores del JSON parseado al objeto de salida\n    outputObj.sector = parsedJson.sectors?.[0] || \"\";\n    outputObj.location = parsedJson.location || \"\";\n    outputObj.limit = parseInt(parsedJson.limit) || 40;\n    outputObj.minRating = parseInt(parsedJson.minRating) || 2;\n    outputObj.minReviews = parseInt(parsedJson.minReviews) || 1;\n\n    // Construye la searchQuery\n    outputObj.searchQuery = `${outputObj.sector} ${outputObj.location}`.trim();\n  }\n\n} catch (e) {\n  console.log(\"Error al procesar el texto:\", e.message);\n}\n\n// Devuelve el objeto de salida como un array con un solo elemento\nreturn [outputObj];"
      },
