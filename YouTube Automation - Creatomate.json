        "messages": {
          "values": [
            {
              "content": "=You are a viral YouTube Shorts content strategist. Today is {{ $now.format('YYYY-MM-DD') }}.\n\nCreate 2 video ideas that combine current world events/trends with deep philosophical or motivational lessons. Think about AI, economy, geopolitics, human behaviour.\n\nReturn ONLY a valid JSON array with exactly 2 objects. No markdown, no explanation.\n\nEach object must have:\n- id: '{{ $now.format('YYYYMMDD') }}_01' and '{{ $now.format('YYYYMMDD') }}_02'\n- idea: powerful title 8-12 words max\n- caption: 2-3 sentences with the philosophical angle and lesson\n- channel_style_prompt: narration tone for voiceover (e.g. 'deep, calm, motivational narrator')\n- character_style_prompt: visual style for AI image generator (e.g. 'cinematic eagle, dramatic sky, photorealistic')\n- production_status: always 'production'"
            }
          ]
        },
        "options": {}
      },
